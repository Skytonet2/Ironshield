# .env.test.example — copy to .env.test for local-only testing
#
# These overrides land alongside .env / .env.local. The backend reads
# .env.test on top of .env.local when NODE_ENV=test (or when started
# via npm run backend:test). Real secrets stay in .env / .env.local;
# this file is only the test-shaped overrides — safe to commit example
# values.

# Test Postgres spun up by docker-compose.test.yml
DATABASE_URL=postgresql://test:test@localhost:5433/ironshield_test

# Distinct port so a real local backend on :3001 doesn't collide
BACKEND_PORT=3002
BACKEND_URL=http://localhost:3002

# Frontend points at the test backend
NEXT_PUBLIC_BACKEND_URL=http://localhost:3002

# Test against testnet so the contract calls don't touch mainnet state
NEXT_PUBLIC_NETWORK_ID=testnet
NEAR_RPC_URL=https://rpc.testnet.near.org
CONTRACT_ID=ironshield-test.testnet

# Allow the local frontend on :3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Generate fresh secrets so a leaked .env.test doesn't leak prod
# (these only sign tokens used by the test stack):
#   openssl rand -hex 32
WS_TICKET_SECRET=test-ws-secret-replace-me

# Permissive admin in local — first connected wallet boots as admin
ADMIN_WALLET_SEED=alice-test.testnet

# Disable real outbound work in tests
TELEGRAM_BOT_TOKEN=
NEAR_AI_KEY=
CLOUDINARY_API_KEY=
LIVEKIT_API_KEY=

# Keep AI budget very low so a runaway test trips the cap quickly
DAILY_AI_BUDGET_USD=0.10

# Tag log lines so test-vs-real-traffic is obvious in any combined view
NODE_ENV=test
