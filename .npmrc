; npm peer-dep strictness loosened so Render's default `npm install`
; accepts the @privy-io/react-auth ↔ @solana-program/memo conflict
; that @solana/kit v6 shipped. All installs (root + backend) go
; through this file, so the fix survives across deploys without
; having to override Render's build command.
legacy-peer-deps=true
