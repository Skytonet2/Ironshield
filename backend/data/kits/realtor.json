{
  "$schema": "../kits.schema.json",
  "slug": "realtor",
  "title": "Realtor Agent",
  "vertical": "realestate",
  "description": "Scouts apartment / house listings across Facebook Groups + jiji.ng, scores each for scam likelihood, drafts a negotiation message, and ships outreach via the user's preferred channel. Best-effort across fragile sources — graceful degradation when any one scout is dormant.",
  "hero_image_url": null,
  "example_missions": [
    "Find 3 unfurnished 2-bedroom apartments in Lekki under ₦3M/yr",
    "Scout 5 plots of land in Ibadan under ₦15M with verified titles"
  ],
  "required_connectors": ["facebook", "jiji"],
  "optional_connectors":  ["whatsapp", "tg", "x", "email"],
  "bundled_skills": [
    {
      "skill": "builtin:scout_fb",
      "params": {
        "group_id": "$preset.fb_group_ids[0]",
        "limit":    25,
        "filter":   "$preset.query"
      }
    },
    {
      "skill": "builtin:scout_jiji",
      "params": {
        "query":     "$preset.query",
        "location":  "$preset.location",
        "min_price": "$preset.price_range.min",
        "max_price": "$preset.price_range.max",
        "limit":     20
      }
    },
    {
      "skill": "builtin:verifier_listing",
      "params": {
        "listing": "$prev.items[0]"
      }
    },
    {
      "skill": "builtin:negotiator",
      "params": {
        "listing_title": "$1.items[0].title",
        "listing_price": "$1.items[0].price_text",
        "target_price":  "$preset.price_range.max",
        "language":      "$preset.language",
        "tone":          "$preset.tone"
      }
    },
    {
      "skill": "builtin:outreach_dm",
      "params": {
        "target":  "$preset.contact_handle",
        "message": "$prev.message"
      }
    }
  ],
  "preset_config_schema": {
    "type": "object",
    "required": ["query", "location", "price_range", "type"],
    "properties": {
      "query": {
        "type": "string",
        "minLength": 2,
        "description": "Free-text query — e.g. '2-bedroom apartment'"
      },
      "location": {
        "type": "string",
        "description": "Nigerian city / state. Used by Jiji filter and FB Group selection."
      },
      "price_range": {
        "type": "object",
        "required": ["min", "max", "currency"],
        "properties": {
          "min": { "type": "number", "minimum": 0 },
          "max": { "type": "number", "minimum": 0 },
          "currency": { "type": "string", "default": "NGN" }
        }
      },
      "type": {
        "type": "string",
        "enum": ["rent", "sale"],
        "description": "Rental or outright sale"
      },
      "language": {
        "type": "string",
        "default": "English",
        "description": "Outreach + negotiation language"
      },
      "tone": {
        "type": "string",
        "default": "warm-professional",
        "enum": ["warm-professional", "casual", "blunt"]
      },
      "fb_group_ids": {
        "type": "array",
        "items": { "type": "string" },
        "description": "Optional: Facebook Group IDs the user is a member of. Leave empty to skip FB scout."
      },
      "contact_handle": {
        "type": "string",
        "description": "Where to send the negotiator's draft — e.g. a phone number for WhatsApp, a TG chat id, an email address. Channel is picked by outreach_dm based on what you've connected."
      }
    }
  },
  "default_pricing": {
    "model": "per_mission",
    "amount_yocto": "1000000000000000000000000",
    "token": "NEAR"
  },
  "revenue_split_bps": {
    "kit_curator": 1500,
    "agent_owner": 7500,
    "platform":     1000
  },
  "status": "beta"
}
