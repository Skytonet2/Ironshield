{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "ironshield-dev",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["next", "dev"],
      "port": 3000,
      "autoPort": true
    },
    {
      "name": "ironshield-backend",
      "runtimeExecutable": "node",
      "runtimeArgs": ["backend/server.js"],
      "port": 3001
    },
    {
      "name": "ironshield-prod",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["serve", "-s", "out", "-l", "3002", "--no-clipboard"],
      "port": 3002
    }
  ]
}
