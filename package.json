{
  "name": "ironshield",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "bot": "node bot/index.js",
    "backend": "node backend/server.js",
    "governance": "node backend/services/governanceListener.js",
    "jobs": "node -e \"require('./jobs/dailySummary.job'); require('./jobs/portfolioUpdate.job'); require('./jobs/alertTrigger.job');\"",
    "db:migrate": "node -e \"require('./backend/db/client').migrate().then(() => process.exit(0)).catch(e => { console.error(e); process.exit(1); })\"",
    "autonomous": "node agent/autonomousLoop.js",
    "ironclaw": "concurrently \"npm run backend\" \"npm run bot\" \"npm run governance\" \"npm run jobs\" \"npm run autonomous\"",
    "dev:all": "concurrently \"npm run dev\" \"npm run ironclaw\""
  },
  "dependencies": {
    "@here-wallet/core": "^3.4.0",
    "@jup-ag/api": "^6.0.48",
    "@livekit/components-react": "^2.6.10",
    "@livekit/components-styles": "^1.1.6",
    "@near-wallet-selector/core": "^10.1.4",
    "@near-wallet-selector/here-wallet": "^10.1.4",
    "@near-wallet-selector/hot-wallet": "^10.1.4",
    "@near-wallet-selector/intear-wallet": "^10.1.4",
    "@near-wallet-selector/meteor-wallet": "^10.1.4",
    "@near-wallet-selector/modal-ui": "^10.1.4",
    "@near-wallet-selector/my-near-wallet": "^10.1.4",
    "@privy-io/react-auth": "^3.22.1",
    "@solana-program/memo": "^0.11.0",
    "@solana/wallet-adapter-base": "^0.9.27",
    "@solana/web3.js": "^1.98.4",
    "busboy": "^1.6.0",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.18.2",
    "framer-motion": "^11.18.2",
    "helmet": "^8.1.0",
    "lightweight-charts": "^5.1.0",
    "livekit-client": "^2.7.5",
    "livekit-server-sdk": "^2.9.0",
    "lucide-react": "^1.7.0",
    "nanoid": "^5.1.9",
    "near-api-js": "^6.5.1",
    "next": "16.2.2",
