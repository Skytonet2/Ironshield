# ─── Next.js ───────────────────────────────────────────────────
NEXT_PUBLIC_NETWORK_ID=mainnet
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ─── Telegram Bot ───────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Webhook URL for production (polling used for dev)
WEBHOOK_URL=https://ironshield.near.page

# Channel/group the governance pusher posts to (e.g. -1001234567890 or @IronClawHQ)
# The bot must be an admin in this channel.
TELEGRAM_GOVERNANCE_CHAT_ID=

# ─── Governance Agent (vote aggregator) ─────────────────────────
# NEAR account that signs finalize_proposal / execute_proposal txs.
# Generate a key with: near account create-account ironclaw-agent.near
# Then export AGENT_PRIVATE_KEY from ~/.near-credentials/mainnet/<acc>.json
AGENT_ACCOUNT_ID=
AGENT_PRIVATE_KEY=

# Override the staking contract or poll cadence if needed
STAKING_CONTRACT_ID=ironshield.near
GOV_POLL_INTERVAL_MS=300000
NEAR_RPC_URL=https://rpc.mainnet.near.org

# ─── Backend ────────────────────────────────────────────────────
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001

# ─── IronClaw (NEAR AI Cloud — PRIMARY agent runtime) ───────────
# IronClaw is NEAR's hosted secure-agent runtime. IronShield is a
# tenant on it — we do NOT run our own agent runtime. Our agent
# lives at stark-goat.agent0.near.ai. The gateway token below
# authenticates our backend to IronClaw's REST API (chat, memory,
# skills, routines). Issue a scoped token via POST /api/tokens on
# the IronClaw dashboard. NEVER check a real token into git.
IRONCLAW_BASE_URL=https://stark-goat.agent0.near.ai
IRONCLAW_GATEWAY_TOKEN=
# Flip to "true" to route agentConnector through IronClaw threads.
# Default "false" keeps the legacy chat-completions path.
IRONCLAW_AGENT_MODE=false

# ─── Legacy direct chat-completions (fallback) ──────────────────
# Kept so existing agentConnector flows keep working while we
# migrate to the IronClaw agent platform. Get a key from app.near.ai.
NEAR_AI_ENDPOINT=https://cloud-api.near.ai/v1/chat/completions
NEAR_AI_KEY=your_near_ai_key_here
NEAR_AI_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ironshield

# ─── Admin ──────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_PW=ironshield_admin

# ─── On-chain contract ──────────────────────────────────────────
CONTRACT_ID=ironshield.near

# ─── Mission Executor (orchestrator identity) ───────────────────
# Hot key for backend/services/missionExecutor.js. Must be authorized
# via `set_orchestrator` on the staking contract — only this account
# can call submit_mission_result.
ORCHESTRATOR_ACCOUNT=orchestrator.ironshield.near
ORCHESTRATOR_KEY=
MISSION_POLL_MS=300000

# Fallback secret used by attestation.js when NEAR AI's TEE
# attestation endpoint is unavailable. ROTATE before prod.
ORCHESTRATOR_SECRET=rotate-me-before-prod
NEAR_AI_ATTEST_PATH=/v1/attestation

# Optional: bypass IPFS pinning during dev (uses sha256 placeholder)
IPFS_CID_OVERRIDE=

# ─── Revenue Router (collector identity) ────────────────────────
# Hot key for backend/services/revenueRouter.js. Holds protocol fees
# upstream of the on-chain treasury split (40/25/20/15).
COLLECTOR_ACCOUNT=fees.ironshield.near
COLLECTOR_KEY=
REVENUE_SWEEP_MS=3600000
REVENUE_MIN_YOCTO=100000000000000000000000

# ─── Cloudflare Pages (static-site host) ────────────────────────
# Used by wrangler to deploy Next.js out/ directory. Create a token
# at dash.cloudflare.com > API tokens > Pages:Edit. Rotate if leaked.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=ironshield

# ─── IronFeed "Voices" tab (X/Twitter aggregator) ──────────────
# Comma-separated list of Nitter instances the /api/xfeed routes
# query for per-handle RSS. The first 2xx response wins; the rest
# are fallbacks. Leave blank to disable live tweets — the UI keeps
# rendering the watchlist with a "not configured" banner.
# Example: https://nitter.net,https://nitter.privacydev.net
NITTER_BASE_URL=

# ─── Privy (client-side auth + embedded wallets) ────────────────
# Public App ID — embedded in the browser bundle by design (no secret
# material). Get from dashboard.privy.io → App Settings → Basics.
# Without this set, the /aio sign-in button renders disabled with a
# "Configure NEXT_PUBLIC_PRIVY_APP_ID" hint — the app still boots.
NEXT_PUBLIC_PRIVY_APP_ID=

# ─── Platform fee-collection wallets ────────────────────────────
# Generated once by `node scripts/gen-platform-wallets.js`, which also
# writes the full keypairs to /secrets/platform-wallets.json (gitignored).
# Paste the three public addresses the script prints here. The 0.2%
# trading fee path reads these at request time — never hardcode.
PLATFORM_WALLET_NEAR=
PLATFORM_WALLET_SOL=
PLATFORM_WALLET_BNB=

# ─── Pikespeak (NEAR on-chain event indexer) ────────────────────
# Server-side only — never prefix with NEXT_PUBLIC_* or the key leaks
# into the browser bundle. Sign up at docs.pikespeak.ai. Used by the
# OHLCV service to pull Ref Finance swap events for general NEAR
# pools (Tier 2). Leave blank to disable — the ohlcv route falls back
# to GeckoTerminal's near-protocol coverage when the key is absent.
PIKESPEAK_API_KEY=

# ─── Optional ───────────────────────────────────────────────────
REDIS_URL=
COINGECKO_API_KEY=
