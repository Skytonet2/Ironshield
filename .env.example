# ─── Next.js ───────────────────────────────────────────────────
NEXT_PUBLIC_NETWORK_ID=mainnet

# ─── Telegram Bot ───────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Webhook URL for production (polling used for dev)
WEBHOOK_URL=https://ironshield.near.page

# ─── IronClaw Backend ───────────────────────────────────────────
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001

# ─── NEAR AI ────────────────────────────────────────────────────
# Get from https://app.near.ai
NEAR_AI_ENDPOINT=https://cloud-api.near.ai/v1/chat/completions
NEAR_AI_KEY=your_near_ai_key_here
NEAR_AI_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ironshield

# ─── Admin ──────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_PW=ironshield_admin

# ─── Optional ───────────────────────────────────────────────────
REDIS_URL=
COINGECKO_API_KEY=
