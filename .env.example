# ─── Next.js ───────────────────────────────────────────────────
NEXT_PUBLIC_NETWORK_ID=mainnet
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# ─── Telegram Bot ───────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Bot mode: "webhook" for production, omit/empty for polling (dev)
BOT_MODE=webhook
WEBHOOK_URL=https://ironclaw.com
WEBHOOK_PORT=8443

# ─── Autonomous Agent ──────────────────────────────────────────
# TG group/channel where IronClaw posts autonomous updates
IRONCLAW_CHANNEL_ID=-100xxxxxxxxxx
# Loop interval in ms (default: 600000 = 10 min)
AUTONOMOUS_LOOP_INTERVAL=600000

# Channel/group the governance pusher posts to (e.g. -1001234567890 or @IronClawHQ)
# The bot must be an admin in this channel.
TELEGRAM_GOVERNANCE_CHAT_ID=

# ─── Governance Agent (vote aggregator) ─────────────────────────
# NEAR account that signs finalize_proposal / execute_proposal txs.
# Generate a key with: near account create-account ironclaw-agent.near
# Then export AGENT_PRIVATE_KEY from ~/.near-credentials/mainnet/<acc>.json
AGENT_ACCOUNT_ID=
AGENT_PRIVATE_KEY=

# Override the staking contract or poll cadence if needed
STAKING_CONTRACT_ID=ironshield.near
GOV_POLL_INTERVAL_MS=300000
NEAR_RPC_URL=https://rpc.mainnet.near.org

# ─── Backend ────────────────────────────────────────────────────
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001

# Browser origins that may call this backend cross-origin. Comma-
# separated list, no trailing slashes. Anything off the list gets no
# Access-Control-Allow-Origin header (browsers reject). In dev,
# http://localhost:3000 is always added on top so `next dev` works.
CORS_ALLOWED_ORIGINS=https://ironshield.pages.dev

# ─── IronClaw (NEAR AI Cloud — PRIMARY agent runtime) ───────────
# IronClaw is NEAR's hosted secure-agent runtime. IronShield is a
# tenant on it — we do NOT run our own agent runtime. Our agent
# lives at stark-goat.agent0.near.ai. The gateway token below
# authenticates our backend to IronClaw's REST API (chat, memory,
# skills, routines). Issue a scoped token via POST /api/tokens on
# the IronClaw dashboard. NEVER check a real token into git.
IRONCLAW_BASE_URL=https://stark-goat.agent0.near.ai
IRONCLAW_GATEWAY_TOKEN=
# Flip to "true" to route agentConnector through IronClaw threads.
# Default "false" keeps the legacy chat-completions path.
IRONCLAW_AGENT_MODE=false

# ─── Legacy direct chat-completions (fallback) ──────────────────
# Kept so existing agentConnector flows keep working while we
# migrate to the IronClaw agent platform. Get a key from app.near.ai.
NEAR_AI_ENDPOINT=https://cloud-api.near.ai/v1/chat/completions
NEAR_AI_KEY=your_near_ai_key_here
NEAR_AI_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ironshield

# ─── Admin ──────────────────────────────────────────────────────
# Admin access is gated by the backend `admin_wallets` table + the
# requireWallet+requireAdmin middleware chain. There is NO client-side
# password — anything bundled into NEXT_PUBLIC_* is shipped to every
# browser and worthless as a secret.
#
# On the very first deploy, set ADMIN_WALLET_SEED to your NEAR account.
# The migration inserts that wallet into admin_wallets if the table is
# empty so a fresh stack isn't locked out. Manage admins after that via
# direct SQL — no UI for adding/removing in v1.
ADMIN_WALLET_SEED=

# ─── On-chain contract ──────────────────────────────────────────
CONTRACT_ID=ironshield.near

# ─── Mission Executor (orchestrator identity) ───────────────────
# Hot key for backend/services/missionExecutor.js. Must be authorized
# via `set_orchestrator` on the staking contract — only this account
# can call submit_mission_result.
ORCHESTRATOR_ACCOUNT=orchestrator.ironshield.near
ORCHESTRATOR_KEY=
MISSION_POLL_MS=300000

# Fallback secret used by attestation.js when NEAR AI's TEE
# attestation endpoint is unavailable. ROTATE before prod.
ORCHESTRATOR_SECRET=rotate-me-before-prod
NEAR_AI_ATTEST_PATH=/v1/attestation

# Optional: bypass IPFS pinning during dev (uses sha256 placeholder)
IPFS_CID_OVERRIDE=

# ─── IronClaw Bridge Relay ──────────────────────────────────────
# Shared HMAC-SHA256 secret between IronShield's backend and the
# external relay posting into /api/ironclaw/bridge/inbound. The same
# secret signs outbound POSTs from outboundRelay() to a linked
# agent's source URL. Generate with:
#   openssl rand -hex 32
# Leave blank to disable bridge inbound/outbound — the health
# endpoint still responds so operators can see the unconfigured state.
IRONCLAW_BRIDGE_SECRET=

# ─── Revenue Router (collector identity) ────────────────────────
# Hot key for backend/services/revenueRouter.js. Holds protocol fees
# upstream of the on-chain treasury split (40/25/20/15).
COLLECTOR_ACCOUNT=fees.ironshield.near
COLLECTOR_KEY=
REVENUE_SWEEP_MS=3600000
REVENUE_MIN_YOCTO=100000000000000000000000

# ─── Cloudflare Pages (static-site host) ────────────────────────
# Used by wrangler to deploy Next.js out/ directory. Create a token
# at dash.cloudflare.com > API tokens > Pages:Edit. Rotate if leaked.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT=ironshield

# ─── Cloudflare R2 (persistent media storage) ───────────────────
# Backs the primary host in /api/media's upload cascade. Without all
# five vars set, the cascade falls through to temp-host fallbacks
# (uguu.se, tmpfiles.org, etc.) which delete uploads after minutes
# to hours — bad for user posts. Provision via dash.cloudflare.com
# → R2 → Create bucket; then API tokens → Create with Object Read
# and Write scope on the bucket. Enable public access on the bucket
# Settings tab to get a pub-*.r2.dev URL, OR bind a custom domain.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ironshield-media
R2_PUBLIC_URL_BASE=

# ─── IronFeed "Voices" tab (X/Twitter aggregator) ──────────────
# Comma-separated list of Nitter instances the /api/xfeed routes
# query for per-handle RSS. The first 2xx response wins; the rest
# are fallbacks. Leave blank to disable live tweets — the UI keeps
# rendering the watchlist with a "not configured" banner.
# Example: https://nitter.net,https://nitter.privacydev.net
NITTER_BASE_URL=

# ─── Privy (client-side auth + embedded wallets) ────────────────
# Public App ID — embedded in the browser bundle by design (no secret
# material). Get from dashboard.privy.io → App Settings → Basics.
# Without this set, the /aio sign-in button renders disabled with a
# "Configure NEXT_PUBLIC_PRIVY_APP_ID" hint — the app still boots.
NEXT_PUBLIC_PRIVY_APP_ID=

# ─── Platform fee-collection wallets ────────────────────────────
# Generated once by `node scripts/gen-platform-wallets.js`, which also
# writes the full keypairs to /secrets/platform-wallets.json (gitignored).
# Paste the three public addresses the script prints here. The 0.2%
# trading fee path reads these at request time — never hardcode.
PLATFORM_WALLET_NEAR=
PLATFORM_WALLET_SOL=
PLATFORM_WALLET_BNB=

# Public-safe aliases for the frontend swap path. Keep these in
# lockstep with the server-side pair above — they're the same
# addresses; the NEXT_PUBLIC_ prefix just opts them into the browser
# bundle. Never add private keys here.
NEXT_PUBLIC_PLATFORM_WALLET_NEAR=
NEXT_PUBLIC_PLATFORM_WALLET_SOL=

# ─── Custodial TG-bot wallet encryption ─────────────────────────
# Required for Phase 7 TG-bot /swap /send commands. Generate with:
#   openssl rand -hex 32
# Never check a real value into git. Store the generated key in
# /secrets/platform-wallets.json as a backup — losing it renders
# every user's custodial balance unrecoverable from our side
# (users can still recover via /withdraw before rotation).
CUSTODIAL_ENCRYPT_KEY=

# ─── Pikespeak (NEAR on-chain event indexer) ────────────────────
# Server-side only — never prefix with NEXT_PUBLIC_* or the key leaks
# into the browser bundle. Sign up at docs.pikespeak.ai. Used by the
# OHLCV service to pull Ref Finance swap events for general NEAR
# pools (Tier 2). Leave blank to disable — the ohlcv route falls back
# to GeckoTerminal's near-protocol coverage when the key is absent.
PIKESPEAK_API_KEY=

# ─── Cloudinary (media uploads) ─────────────────────────────────
# Signed-upload params for /api/profile/upload. Without all three the
# upload endpoint returns 503 and the UI falls back to URL-only avatars.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── LiveKit (Live Alpha Rooms voice) ───────────────────────────
# Self-hosted or LiveKit Cloud. Without these the rooms route returns
# 503 on token mint — text-only rooms still load. Day 19 swaps to a
# managed dev tier; until then point at a self-hosted server.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ─── Web Push (notifications) ───────────────────────────────────
# VAPID keypair for Web Push subscriptions. Generate with:
#   npx web-push generate-vapid-keys
# Only the public key is sent to browsers; the private key signs push
# payloads server-side. Without these set, /api/push routes 503 and
# the in-app bell still works (just no native push).
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ─── WebSocket ticket + session token secret ────────────────────
# Single HMAC secret backing two artifacts:
#   - WS connection tickets (Day 5.5)  — short-lived, single-use
#   - Session bearer tokens (Day 5.6)  — 24h, kills per-action
#                                         signMessage popups
# Both use a domain tag in the signed payload so a leaked WS ticket
# can't be replayed as a session token. If unset the services fall
# back to a process-local random secret — fine for dev, FATAL in
# prod (tokens issued before a restart become unverifiable).
# Generate with: openssl rand -hex 32
WS_TICKET_SECRET=

# ─── Telegram bot / X (Twitter) integrations ────────────────────
# Bot's own @handle (no leading @). Used by the start-message UI to
# build a t.me/<bot>?start=<code> link. If unset that link reads as
# t.me/?start=… and won't open in TG.
TELEGRAM_BOT_USERNAME=

# Shared HMAC secret between bot worker (bot/services/backend.js) and
# this backend (backend/middleware/requireBotSig.js). Every /api/tg/*
# call gets stamped with X-TG-Signature = HMAC-SHA256 over
# `${timestamp}.${rawBody}`; the backend rejects unsigned or stale
# requests. MUST be the same value on both services in production.
# Generate with: `openssl rand -hex 32`. Without this, /api/tg/*
# returns 503 in production (security fail-closed).
TELEGRAM_BOT_BACKEND_SECRET=

# Bearer token for the x.com (Twitter) v2 API. Used by the IronFeed
# "Voices" tab when present; falls through to NITTER_BASE_URL when
# blank. Nitter remains the recommended path — Twitter's own API has
# a hostile rate-limit posture for this kind of use.
TWITTER_BEARER_TOKEN=

# ─── Bridge fee + treasury wallets ──────────────────────────────
# NEAR account that receives the bridge platform fee on inbound
# crossings. Distinct from PLATFORM_WALLET_NEAR (trading fees) and
# COLLECTOR_ACCOUNT (revenue router) so accounting stays clean.
BRIDGE_FEE_RECIPIENT=
# Receiving account for the on-chain treasury split — the 40/25/20/15
# router empties COLLECTOR_ACCOUNT into this account at the
# REVENUE_SWEEP_MS cadence.
PLATFORM_TREASURY=

# ─── Optional ───────────────────────────────────────────────────
REDIS_URL=
COINGECKO_API_KEY=

# ─── Phase 10 Tier 4 — Web2 connectors ──────────────────────────
# Each connector is dormant if its key/account isn't provisioned.
# The dispatcher still registers it, but invoke() throws a helpful
# error so callers can detect and skip.
#
# Frontend origin — used by OAuth callback handlers to construct an
# absolute redirect URL after token exchange. The backend lives on a
# different host from the frontend (backend on Render, frontend on
# Cloudflare Pages), so a relative redirect would land on the backend
# host → 404. Default: https://azuka.pages.dev. Set this to your
# custom domain if you have one (e.g. https://app.example.com).
FRONTEND_URL=https://azuka.pages.dev

# Bot HTTP fallback — for split deployments where the bot runs in a
# process separate from the backend. When BACKEND_INBOUND_URL is set
# AND ORCHESTRATOR_SHARED_SECRET is set, the bot POSTs inbound TG
# messages to <backend>/api/connectors/tg/inbound so scout_tg's ring
# buffer fills. Co-located deployments don't need either var; the
# bot prefers the in-process eventBus.
BACKEND_INBOUND_URL=
ORCHESTRATOR_SHARED_SECRET=

# X (Twitter) API v2 — app-level bearer for read-only paths
# (search, mentions). User OAuth tokens for post / DM are stored
# encrypted per-wallet in connector_credentials via the
# /api/connectors/x/connect flow.
X_BEARER_TOKEN=

# X OAuth 2.0 client credentials — created at developer.x.com.
# Required for the /api/connectors/x/oauth/* flow that issues
# user-context tokens. Redirect URI must match exactly what's
# registered with X. Without these, the X "Connect with OAuth"
# button returns 503 X_OAUTH_NOT_CONFIGURED.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=https://ironshield.io/api/connectors/x/oauth/callback

# Shared secret for signing the short-lived OAuth state cookie. If
# unset we fall back to CUSTODIAL_ENCRYPT_KEY so a misconfigured
# deploy still works (with a warning) instead of bricking the
# connect flow. Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=

# Facebook (Meta) Graph API — OAuth 2.0 user-context tokens are
# stored per-wallet in connector_credentials. The app id + secret
# below are needed for the OAuth handshake at /api/connectors/facebook/connect.
# Marketplace search is NOT supported by Graph API — the Realtor /
# Car-Sales kits fall back to the jiji connector for classifieds.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_OAUTH_REDIRECT_URI=https://ironshield.io/api/connectors/facebook/oauth/callback

# Google OAuth 2.0 — for the email connector's "Sign in with Google"
# flow. Configured at console.cloud.google.com → APIs & Services →
# Credentials → OAuth 2.0 Client IDs (Web application). Authorized
# redirect URIs must include the value below verbatim. The client
# secret is server-only.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://ironshield.io/api/connectors/email/oauth/google/callback

# Microsoft (Outlook / Microsoft 365) OAuth 2.0 — for the email
# connector's "Sign in with Microsoft" flow. Registered at
# entra.microsoft.com → App registrations → New registration. Use
# the multi-tenant + personal accounts option so consumer outlook.com
# users can sign in too. Redirect URI must match exactly.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_OAUTH_REDIRECT_URI=https://ironshield.io/api/connectors/email/oauth/microsoft/callback

# WhatsApp Business Cloud API — system-user access tokens are stored
# per-wallet in connector_credentials. The verify token below is the
# platform-shared secret Meta sends as hub.verify_token during
# webhook setup. The app secret is optional but enables HMAC sig
# verification (X-Hub-Signature-256) on inbound webhooks.
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
