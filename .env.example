# ─── Next.js ───────────────────────────────────────────────────
NEXT_PUBLIC_NETWORK_ID=mainnet

# ─── Telegram Bot ───────────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Bot mode: "webhook" for production, omit/empty for polling (dev)
BOT_MODE=webhook
WEBHOOK_URL=https://ironclaw.com
WEBHOOK_PORT=8443

# ─── Autonomous Agent ──────────────────────────────────────────
# TG group/channel where IronClaw posts autonomous updates
IRONCLAW_CHANNEL_ID=-100xxxxxxxxxx
# Loop interval in ms (default: 600000 = 10 min)
AUTONOMOUS_LOOP_INTERVAL=600000

# ─── IronClaw Backend ───────────────────────────────────────────
BACKEND_PORT=3001
BACKEND_URL=http://localhost:3001

# ─── NEAR AI ────────────────────────────────────────────────────
# Get from https://app.near.ai
NEAR_AI_ENDPOINT=https://cloud-api.near.ai/v1/chat/completions
NEAR_AI_KEY=your_near_ai_key_here
NEAR_AI_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# ─── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ironshield

# ─── Admin ──────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_PW=ironshield_admin

# ─── Optional ───────────────────────────────────────────────────
REDIS_URL=
COINGECKO_API_KEY=
